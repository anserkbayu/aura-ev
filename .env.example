# ============================================
# SUPABASE CONFIGURATION
# ============================================
# Copy file ini jadi .env dan isi dengan API keys kamu

# Project URL dari Supabase Dashboard > Settings > API
SUPABASE_URL=https://xxxxxxxxxxxxx.supabase.co

# Anon/Public Key - AMAN untuk frontend
SUPABASE_ANON_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9...

# Service Role Key - RAHASIA! Hanya untuk backend
SUPABASE_SERVICE_ROLE_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9...

# ============================================
# ADMIN CREDENTIALS (untuk testing)
# ============================================
ADMIN_EMAIL=adminaura@gmail.com
ADMIN_PASSWORD=admin123

# ============================================
# NOTES
# ============================================
# - Jangan commit file .env ke Git!
# - File .env sudah ada di .gitignore
# - Service Role Key jangan dipakai di frontend!
